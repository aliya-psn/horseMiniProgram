@import '../index/index.wxss';

page {
  background: linear-gradient(180deg, #fff5e6 0%, #ffe8cc 100%);
}

.sbti-page {
  min-height: 100vh;
  position: relative;
}

.sbti-page-bg.page-index-bg {
  z-index: 0;
}

.sbti-inner {
  position: relative;
  z-index: 1;
  padding: 32rpx 28rpx 80rpx;
  max-width: 700rpx;
  margin: 0 auto;
}

.q-meta {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.q-num {
  font-size: 26rpx;
  flex-shrink: 0;
  color: #8a7355;
}

.q-dim {
  font-size: 26rpx;
  font-weight: 600;
  color: #c8102e;
  text-align: right;
  flex: 1;
  min-width: 0;
}

.q-card {
  background: linear-gradient(135deg, #fffbf7 0%, #fff8f0 100%);
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(200, 16, 46, 0.08);
  border: 2rpx solid #e8d5b7;
}

.q-title {
  font-size: 30rpx;
  line-height: 1.55;
  color: #3d3426;
  display: block;
  margin-bottom: 28rpx;
}

.q-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.opt {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 20rpx;
  border-radius: 20rpx;
  background: #fffefb;
  border: 2rpx solid #e8d5b7;
  transition: border-color 0.15s, background 0.15s;
}

.opt-on {
  border-color: #c8102e;
  background: rgba(200, 16, 46, 0.06);
}

.opt-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d4af37;
  margin-right: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.opt-on .opt-radio {
  border-color: #c8102e;
}

.opt-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #c8102e 0%, #d4af37 100%);
}

.opt-key {
  font-size: 28rpx;
  font-weight: 600;
  color: #8a7355;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.opt-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
}

.opt-pill {
  flex-shrink: 0;
  margin-left: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.pill-pos {
  background: rgba(82, 196, 26, 0.12);
  color: #237804;
}

.pill-zero {
  background: rgba(212, 175, 55, 0.15);
  color: #8a6912;
}

.pill-neg {
  background: rgba(200, 16, 46, 0.1);
  color: #c8102e;
}

.btn-next {
  margin-top: 40rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #c8102e 0%, #d4af37 100%);
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(200, 16, 46, 0.35);
}

.btn-next[disabled] {
  opacity: 0.45;
  box-shadow: none;
}

.btn-next::after {
  border: none;
}
