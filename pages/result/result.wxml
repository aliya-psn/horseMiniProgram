<!-- ========== 结果页 - 全页面视觉大升级 ==========
     红金渐变+祥云背景、马到成功印章、马纹金线边框、维度金色小图标、卡片弹出动效、按钮统一 -->
<view class="page-result">
  <!-- 背景：与首页/答题页一致 -->
  <view class="page-result-bg" style="background: {{theme.bg}};">
    <view class="cloud-texture rc-1"></view>
    <view class="cloud-texture rc-2"></view>
  </view>

  <!-- 结果卡片：顶部“马到成功”印章、马纹金线边框、四周金元宝点缀、加载时从下往上弹出 -->
  <view class="result-card">
    <!-- 马到成功印章 -->
    <view class="seal-wrap">
      <text class="seal-text">马到成功</text>
    </view>
    <text class="result-label text-gold" style="color: {{theme.secondary}};">你的2026运势</text>
    <text class="result-title result-title-gradient" style="color: {{theme.primary}};">{{resultTitle}}</text>
    <!-- 运势标签 chip -->
    <view class="result-tags" wx:if="{{resultTags.length > 0}}">
      <text class="result-tag" wx:for="{{resultTags}}" wx:key="*this" style="color: {{theme.secondary}}; border-color: {{theme.secondary}};">{{item}}</text>
    </view>
    <text class="result-keywords" style="color: {{theme.textSecondary}};">{{resultKeywords}}</text>
    <text class="result-percentile" style="color: {{theme.textSecondary}};">超过 {{resultPercentile}}% 的用户，今年运势不如你</text>
    <!-- 卡片四角金元宝/铜钱点缀（CSS 小圆点模拟） -->
    <view class="card-corner card-tl"></view>
    <view class="card-corner card-tr"></view>
    <view class="card-corner card-bl"></view>
    <view class="card-corner card-br"></view>
  </view>

  <!-- 四维度详细解读：每项前加金色小图标（事业=元宝 人际=人 健康=心 建议=灯） -->
  <view class="result-details" wx:if="{{resultSections.length > 0}}">
    <view class="detail-section" wx:for="{{resultSections}}" wx:key="label">
      <text class="detail-icon-symbol" style="color: {{theme.secondary}};">{{item.iconChar}}</text>
      <view class="detail-body">
        <text class="detail-label" style="color: {{theme.textPrimary}};">{{item.label}}</text>
        <text class="detail-content" style="color: {{theme.textSecondary}};">{{item.content}}</text>
      </view>
    </view>
  </view>

  <!-- 合规提示：小号灰色，不突兀 -->
  <view class="disclaimer">
    <text class="disclaimer-text">本测试仅供娱乐参考，不作任何现实依据，美好生活靠自己努力！</text>
  </view>

  <view class="ad-interstitial-placeholder ad-hidden">
    <text class="ad-label">[插屏广告位]</text>
    <text class="ad-hint">替换方式：在 result.js 中调用 wx.createInterstitialAd({ adUnitId: '...' })</text>
  </view>

  <!-- 按钮区：分享给朋友、生成海报、重新测试 -->
  <view class="actions">
    <view class="actions-row">
      <button class="btn-action" open-type="share">分享给朋友</button>
      <button class="btn-action" bindtap="onSaveImage">生成我的运势海报</button>
    </view>
    <button class="btn-retest" bindtap="onRetest">重新测试</button>
  </view>

  <!-- 生成中：金粉飘落动效 -->
  <view class="poster-loading-mask" wx:if="{{generatingPoster}}" catchtap="">
    <view class="poster-loading-gold-dust">
      <view class="gold-dot g1"></view>
      <view class="gold-dot g2"></view>
      <view class="gold-dot g3"></view>
      <view class="gold-dot g4"></view>
      <view class="gold-dot g5"></view>
      <view class="gold-dot g6"></view>
      <view class="gold-dot g7"></view>
      <view class="gold-dot g8"></view>
    </view>
    <text class="poster-loading-text">生成中…</text>
  </view>

  <!-- 海报预览：生成后先展示，用户确认再保存到相册 -->
  <view class="poster-preview-mask" wx:if="{{showPosterPreview}}" catchtap="onClosePosterPreview">
    <view class="poster-preview-box" catchtap="">
      <image class="poster-preview-img" src="{{posterPreviewUrl}}" mode="widthFix" />
      <view class="poster-preview-actions">
        <button class="poster-btn poster-btn-save" bindtap="onSavePosterToAlbum">保存到相册</button>
        <button class="poster-btn poster-btn-close" bindtap="onClosePosterPreview">关闭</button>
      </view>
    </view>
  </view>

  <!-- 用于生成运势图的画布（屏外绘制，必须设置 style 宽高与绘制尺寸一致 600*800） -->
  <canvas
    canvas-id="fortuneCanvas"
    style="position: fixed; left: -9999px; top: 0; width: 600px; height: 800px;"
  ></canvas>
</view>
