<!-- ========== 答题页 - 全页面视觉大升级 ==========
     红金渐变+祥云背景、题号栏马蹄印、选项金边+选中放大、点击高亮+滑动动效 -->
<view class="page-quiz" wx:if="{{currentQuestion}}">
  <!-- 背景：与首页一致的红金渐变+祥云纹理 -->
  <view class="page-quiz-bg">
    <view class="cloud-texture qc-1"></view>
    <view class="cloud-texture qc-2"></view>
  </view>

  <!-- 题号栏：浅金渐变条 + 左侧马蹄印 + 金色字体 -->
  <view class="progress-bar">
    <view class="hoof-print-small"></view>
    <text class="progress-text">第{{currentIndex + 1}}题 / {{total}}题</text>
  </view>

  <view class="question-card">
    <text class="question-title">{{currentQuestion.title}}</text>
    <view class="options">
      <view
        class="option-item {{selectedScore === item.score ? 'option-selected' : ''}}"
        wx:for="{{currentQuestion.options}}"
        wx:key="id"
        data-score="{{item.score}}"
        bindtap="onSelectOption"
      >
        <text class="option-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- 下一题：未选题时禁用，选题后可点 -->
  <view class="quiz-actions">
    <button
      class="btn-next {{selectedScore != null ? 'btn-next-enabled' : ''}}"
      disabled="{{selectedScore == null}}"
      bindtap="onNextQuestion"
    >{{currentIndex + 1 >= total ? '查看结果' : '下一题'}}</button>
  </view>
</view>
